{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gestion-cuverie-cidricole.local/schemas/user-profile.schema.json",
  "title": "UserProfile",
  "type": "object",
  "required": ["id", "email", "fullName", "role", "siteIds", "active", "createdAt", "updatedAt"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "email": { "type": "string", "format": "email" },
    "fullName": { "type": "string", "minLength": 2 },
    "role": { "enum": ["admin", "cellar_manager", "operator", "quality_technician"] },
    "defaultSiteId": { "type": "string", "format": "uuid" },
    "siteIds": { "type": "array", "items": { "type": "string", "format": "uuid" }, "minItems": 1 },
    "active": { "type": "boolean" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}

